    "@angular/platform-browser-dynamic": "^21.1.5",
    "@angular/router": "^21.1.0",
    "@angular/service-worker": "^21.2.17",
    "@sentry/angular": "^8.55.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
